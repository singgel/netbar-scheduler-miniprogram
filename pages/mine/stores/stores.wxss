.detail-card {
  padding: 26rpx;
  border: 1rpx solid #edf0f5;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 41, 0.04);
  box-sizing: border-box;
}

.card-title {
  color: #1f2329;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 40rpx;
  margin-bottom: 20rpx;
}

.store-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #f2f3f5;
}

.store-row:first-of-type {
  border-top: 0;
}

.store-dot {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 16rpx;
  background: #e8f8ef;
  color: #07c160;
  font-size: 28rpx;
  font-weight: 800;
}

.store-main {
  min-width: 0;
  flex: 1;
}

.store-name {
  color: #1f2329;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 38rpx;
}

.store-address,
.store-meta {
  color: #8a8f99;
  font-size: 23rpx;
  line-height: 32rpx;
  margin-top: 4rpx;
}

.empty-line {
  min-height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8a8f99;
  font-size: 24rpx;
  border-top: 1rpx solid #f2f3f5;
}
