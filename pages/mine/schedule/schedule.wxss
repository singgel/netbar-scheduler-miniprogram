.detail-card {
  padding: 26rpx;
  border: 1rpx solid #edf0f5;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 41, 0.04);
  box-sizing: border-box;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.range-select {
  min-height: 48rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #1f2329;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 48rpx;
}

.range-arrow {
  width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f2f3f5;
  flex-shrink: 0;
}

.range-arrow::after {
  content: "";
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-top: 8rpx solid #8a8f99;
  margin-top: 2rpx;
}

.schedule-count {
  height: 44rpx;
  display: flex;
  align-items: center;
  border-radius: 999rpx;
  padding: 0 18rpx;
  background: #e8f8ef;
  color: #07c160;
  font-size: 22rpx;
  font-weight: 700;
}

.schedule-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid #f2f3f5;
}

.date-chip {
  width: 72rpx;
  min-height: 72rpx;
  display: grid;
  align-content: center;
  justify-items: center;
  flex-shrink: 0;
  border-radius: 16rpx;
  background: #f2f7ff;
}

.date-day {
  color: #1677ff;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 34rpx;
}

.date-week {
  color: #5f8fd9;
  font-size: 20rpx;
  line-height: 26rpx;
}

.schedule-main {
  min-width: 0;
  flex: 1;
}

.schedule-title {
  color: #1f2329;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 38rpx;
}

.schedule-meta {
  color: #8a8f99;
  font-size: 23rpx;
  line-height: 32rpx;
  margin-top: 4rpx;
}

.schedule-row.past {
  opacity: 0.5;
}

.schedule-row.past .date-chip {
  background: #f2f3f5;
}

.schedule-row.past .date-day {
  color: #8a8f99;
}

.schedule-row.past .date-week {
  color: #b3b6bd;
}

.schedule-row.past .schedule-title {
  color: #8a8f99;
}

.empty-line {
  min-height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8a8f99;
  font-size: 24rpx;
  border-top: 1rpx solid #f2f3f5;
}
