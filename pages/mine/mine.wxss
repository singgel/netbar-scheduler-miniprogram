.mine-page {
  display: grid;
  gap: 20rpx;
}

.profile-hero {
  min-height: 144rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 26rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #ffffff 0%, #eefaf4 100%);
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 41, 0.04);
  box-sizing: border-box;
}

.profile-avatar-wrap {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  flex-shrink: 0;
}

.profile-avatar,
.profile-avatar-img {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  overflow: hidden;
  box-sizing: border-box;
}

.profile-avatar {
  background: #07c160;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 800;
}

.profile-avatar-img {
  background: #f2f3f5;
}

.avatar-camera {
  position: absolute;
  right: -2rpx;
  bottom: -2rpx;
  width: 30rpx;
  height: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #ffffff;
  border-radius: 50%;
  background: #1677ff;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(22, 119, 255, 0.2);
  box-sizing: border-box;
}

.profile-main {
  min-width: 0;
}

.profile-name {
  color: #1f2329;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 54rpx;
}

.profile-subtitle {
  color: #646a73;
  font-size: 25rpx;
  line-height: 36rpx;
  margin-top: 4rpx;
}

.mine-card {
  padding: 26rpx;
  border: 1rpx solid #edf0f5;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 41, 0.04);
  box-sizing: border-box;
}

.mine-menu {
  border: 1rpx solid #edf0f5;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 41, 0.04);
  overflow: hidden;
}

.mine-menu-row {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-top: 1rpx solid #f2f3f5;
  box-sizing: border-box;
}

.mine-menu-row:first-child {
  border-top: 0;
}

.menu-icon {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.icon-profile {
  background: #f2f7ff;
  color: #1677ff;
}

.icon-store {
  background: #e8f8ef;
  color: #07c160;
}

.icon-schedule {
  background: #fff7e6;
  color: #f59f00;
}

.menu-main {
  min-width: 0;
  flex: 1;
}

.menu-title {
  color: #1f2329;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 40rpx;
}

.menu-summary {
  color: #8a8f99;
  font-size: 23rpx;
  line-height: 32rpx;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-arrow {
  color: #c9cdd4;
  font-size: 44rpx;
  line-height: 44rpx;
  flex-shrink: 0;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.card-title {
  color: #1f2329;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 40rpx;
  margin-bottom: 20rpx;
}

.card-head .card-title {
  margin-bottom: 0;
}

.schedule-count {
  height: 44rpx;
  display: flex;
  align-items: center;
  border-radius: 999rpx;
  padding: 0 18rpx;
  background: #e8f8ef;
  color: #07c160;
  font-size: 22rpx;
  font-weight: 700;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.info-item {
  min-width: 0;
  display: grid;
  gap: 6rpx;
}

.info-item.full {
  grid-column: 1 / -1;
}

.info-label {
  color: #8a8f99;
  font-size: 22rpx;
  line-height: 30rpx;
}

.info-value {
  color: #343842;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 36rpx;
  word-break: break-all;
}

.store-row,
.schedule-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid #f2f3f5;
}

.store-row:first-of-type,
.schedule-row:first-of-type {
  border-top: 0;
}

.store-dot {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 16rpx;
  background: #e8f8ef;
  color: #07c160;
  font-size: 28rpx;
  font-weight: 800;
}

.store-main,
.schedule-main {
  min-width: 0;
  flex: 1;
}

.store-name,
.schedule-title {
  color: #1f2329;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 38rpx;
}

.store-address,
.schedule-meta {
  color: #8a8f99;
  font-size: 23rpx;
  line-height: 32rpx;
  margin-top: 4rpx;
}

.date-chip {
  width: 72rpx;
  min-height: 72rpx;
  display: grid;
  align-content: center;
  justify-items: center;
  flex-shrink: 0;
  border-radius: 16rpx;
  background: #f2f7ff;
}

.date-day {
  color: #1677ff;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 34rpx;
}

.date-week {
  color: #5f8fd9;
  font-size: 20rpx;
  line-height: 26rpx;
}

.empty-line {
  min-height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8a8f99;
  font-size: 24rpx;
  border-top: 1rpx solid #f2f3f5;
}

.logout-action {
  height: 88rpx;
  border-radius: 14rpx;
  background: #fff2f0;
  color: #e64340;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 88rpx;
  margin: 4rpx 0 0;
  padding: 0;
  box-shadow: none;
}

.logout-action::after {
  border: 0;
}
