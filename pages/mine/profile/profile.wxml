<view class="page detail-page">
  <view class="detail-card">
    <view class="card-title">个人信息</view>
    <view class="info-grid">
      <view class="info-item">
        <text class="info-label">姓名</text>
        <text class="info-value">{{staff.name || '未填写'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">职位</text>
        <text class="info-value">{{staff.role || roleText}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">性别</text>
        <text class="info-value">{{staff.gender || '未填写'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">年龄</text>
        <text class="info-value">{{staff.age || '未填写'}}</text>
      </view>
      <view class="info-item full">
        <text class="info-label">手机号</text>
        <text class="info-value">{{phoneText}}</text>
      </view>
      <view class="info-item full">
        <text class="info-label">身份证号</text>
        <text class="info-value">{{staff.idCard || '未填写'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">入职时间</text>
        <text class="info-value">{{staff.hireDate || '未填写'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">每周上限</text>
        <text class="info-value">{{staff.maxPerWeek || 0}} 班</text>
      </view>
    </view>
  </view>
</view>
