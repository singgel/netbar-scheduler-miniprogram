.schedule-page {
  padding-bottom: 40rpx;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.title {
  color: #1d1d1f;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 54rpx;
  white-space: nowrap;
}

.month-actions {
  display: flex;
  gap: 12rpx;
}

.mini-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #1d1d1f;
  font-size: 42rpx;
  font-weight: 500;
  line-height: 64rpx;
  border: 0;
  box-shadow: inset 0 0 0 1rpx rgba(0, 0, 0, 0.06);
  padding: 0;
}

.icon-only {
  display: flex;
  align-items: center;
  justify-content: center;
}

.mini-btn::after,
.cell-btn::after,
.step-btn::after {
  border: 0;
}

.toolbar {
  display: grid;
  grid-template-columns: 1fr 156rpx;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.calendar-scroll {
  width: 100%;
}

.calendar {
  min-width: 980rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  border-radius: 24rpx;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 18rpx 48rpx rgba(0, 0, 0, 0.06);
}

.mine-tag {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  border-radius: 999rpx;
  padding: 0 16rpx;
  background: #f5f5f7;
  color: #1d1d1f;
  font-size: 24rpx;
  margin-top: 10rpx;
}

.empty-state {
  background: #ffffff;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  border-radius: 24rpx;
  padding: 28rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.guard-btn {
  margin-top: 20rpx;
}

.grid {
  display: grid;
  grid-template-columns: 156rpx repeat(3, 270rpx);
}

.employee-calendar {
  min-width: 620rpx;
}

.employee-calendar .grid {
  grid-template-columns: 156rpx 1fr;
}

.header-row {
  background: #f5f5f7;
  color: #1d1d1f;
}

.header-cell {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  border-right: 1rpx solid rgba(0, 0, 0, 0.08);
}

.name-cell {
  border-right: 1rpx solid rgba(0, 0, 0, 0.08);
}

.day-row {
  min-height: 168rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.weekend-row .date-cell {
  background: #fafafa;
}

.date-cell {
  background: #fbfbfd;
  padding: 22rpx 12rpx;
  box-sizing: border-box;
}

.date-main {
  color: #1d1d1f;
  font-size: 32rpx;
  font-weight: 800;
  text-align: center;
}

.date-week {
  color: #86868b;
  font-size: 24rpx;
  text-align: center;
  margin-top: 8rpx;
}

.shift-cell {
  min-height: 168rpx;
  padding: 16rpx;
  box-sizing: border-box;
  border-right: 1rpx solid rgba(0, 0, 0, 0.08);
}

.shift-time {
  color: #86868b;
  font-size: 22rpx;
  margin-bottom: 12rpx;
}

.people {
  min-height: 52rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.person,
.empty {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  border-radius: 999rpx;
  padding: 0 14rpx;
  font-size: 24rpx;
}

.person {
  background: #ffffff;
  color: #1d1d1f;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
}

.empty {
  color: #94a3b8;
}

.cell-btn {
  width: 58rpx;
  height: 48rpx;
  margin: 14rpx 0 0;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  color: #1d1d1f;
  font-size: 28rpx;
  line-height: 48rpx;
  border: 0;
  padding: 0;
  box-shadow: inset 0 0 0 1rpx rgba(0, 0, 0, 0.08);
}

.sheet-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(15, 23, 42, 0.42);
  display: flex;
  align-items: flex-end;
  z-index: 10;
}

.sheet {
  width: 100%;
  max-height: 78vh;
  overflow: auto;
  background: #ffffff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 28rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.sheet-title {
  color: #1d1d1f;
  font-size: 34rpx;
  font-weight: 800;
}

.sheet-subtitle {
  margin: 6rpx 0 20rpx;
}

.staff-option {
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.staff-name {
  color: #1d1d1f;
  font-weight: 700;
}

.check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 999rpx;
  text-align: center;
  line-height: 48rpx;
  color: #86868b;
  background: #f5f5f7;
  font-size: 28rpx;
  font-weight: 800;
}

.checked {
  color: #ffffff;
  background: #111111;
}
