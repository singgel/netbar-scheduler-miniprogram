.schedule-page {
  padding-bottom: 40rpx;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.title {
  color: #1f2329;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 54rpx;
  white-space: nowrap;
}

.month-actions {
  display: flex;
  gap: 12rpx;
}

.mini-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #07c160;
  font-size: 42rpx;
  font-weight: 500;
  line-height: 64rpx;
  border: 0;
  box-shadow: 0 4rpx 12rpx rgba(31, 35, 41, 0.06);
  padding: 0;
}

.icon-only {
  display: flex;
  align-items: center;
  justify-content: center;
}

.mini-btn::after,
.cell-btn::after,
.step-btn::after {
  border: 0;
}

.toolbar {
  display: grid;
  grid-template-columns: 1fr 156rpx;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.calendar-scroll {
  width: 100%;
}

.calendar {
  min-width: 980rpx;
  border: 1rpx solid #edf0f5;
  border-radius: 16rpx;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 41, 0.04);
}

.mine-tag {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  border-radius: 8rpx;
  padding: 0 16rpx;
  background: #e8f8ef;
  color: #07c160;
  font-size: 24rpx;
  margin-top: 10rpx;
}

.empty-state {
  background: #ffffff;
  border: 1rpx solid #edf0f5;
  border-radius: 16rpx;
  padding: 28rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.guard-btn {
  margin-top: 20rpx;
}

.grid {
  display: grid;
  grid-template-columns: 156rpx repeat(3, 270rpx);
}

.employee-calendar {
  min-width: 620rpx;
}

.employee-calendar .grid {
  grid-template-columns: 156rpx 1fr;
}

.header-row {
  background: #f7f8fa;
  color: #1f2329;
}

.header-cell {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  border-right: 1rpx solid #edf0f5;
}

.name-cell {
  border-right: 1rpx solid #edf0f5;
}

.day-row {
  min-height: 168rpx;
  border-top: 1rpx solid #edf0f5;
}

.weekend-row .date-cell {
  background: #f7f8fa;
}

.date-cell {
  background: #ffffff;
  padding: 22rpx 12rpx;
  box-sizing: border-box;
}

.date-main {
  color: #1f2329;
  font-size: 32rpx;
  font-weight: 800;
  text-align: center;
}

.date-week {
  color: #8a8f99;
  font-size: 24rpx;
  text-align: center;
  margin-top: 8rpx;
}

.shift-cell {
  min-height: 168rpx;
  padding: 16rpx;
  box-sizing: border-box;
  border-right: 1rpx solid #edf0f5;
}

.shift-time {
  color: #8a8f99;
  font-size: 22rpx;
  margin-bottom: 12rpx;
}

.people {
  min-height: 52rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.person,
.empty {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  border-radius: 999rpx;
  padding: 0 14rpx;
  font-size: 24rpx;
}

.person {
  background: #ffffff;
  color: #1f2329;
  border: 1rpx solid #edf0f5;
}

.empty {
  color: #8a8f99;
}

.cell-btn {
  width: 58rpx;
  height: 48rpx;
  margin: 14rpx 0 0;
  border-radius: 999rpx;
  background: #e8f8ef;
  color: #07c160;
  font-size: 28rpx;
  line-height: 48rpx;
  border: 0;
  padding: 0;
  box-shadow: none;
}

.sheet-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(31, 35, 41, 0.45);
  display: flex;
  align-items: flex-end;
  z-index: 10;
}

.sheet {
  width: 100%;
  max-height: 78vh;
  overflow: auto;
  background: #ffffff;
  border-radius: 20rpx 20rpx 0 0;
  padding: 28rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.sheet-title {
  color: #1f2329;
  font-size: 34rpx;
  font-weight: 800;
}

.sheet-subtitle {
  margin: 6rpx 0 20rpx;
}

.staff-option {
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #edf0f5;
}

.staff-name {
  color: #1f2329;
  font-weight: 700;
}

.check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 999rpx;
  text-align: center;
  line-height: 48rpx;
  color: #8a8f99;
  background: #f2f3f5;
  font-size: 28rpx;
  font-weight: 800;
}

.checked {
  color: #ffffff;
  background: #07c160;
}
