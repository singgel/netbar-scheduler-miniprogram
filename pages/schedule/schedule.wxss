.schedule-page {
  padding-bottom: calc(148rpx + env(safe-area-inset-bottom));
}

.month-switch {
  width: 270rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-radius: 999rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(31, 35, 41, 0.06);
  padding: 0 8rpx;
  box-sizing: border-box;
}

.month-arrow {
  width: 44rpx;
  min-width: 44rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: transparent;
  color: #07c160;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 56rpx;
  border: 0;
  box-shadow: none;
  padding: 0;
  margin: 0;
}

.month-current {
  min-width: 168rpx;
  text-align: center;
  color: #1f2329;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 64rpx;
  white-space: nowrap;
}

.month-arrow::after {
  border: 0;
}

.step-btn::after {
  border: 0;
}

.schedule-tools {
  position: sticky;
  top: 76rpx;
  z-index: 90;
  display: grid;
  gap: 10rpx;
  margin-bottom: 20rpx;
  padding: 12rpx 0 14rpx;
  background: #f7f8fa;
  box-shadow: 0 10rpx 18rpx rgba(247, 248, 250, 0.96);
}

.schedule-tools.manage {
  grid-template-columns: 270rpx minmax(0, 1fr);
  align-items: center;
}

.schedule-tools.employee {
  grid-template-columns: 1fr;
}

.toolbar {
  display: grid;
  grid-template-columns: minmax(132rpx, 1.3fr) minmax(76rpx, 0.75fr) minmax(76rpx, 0.75fr);
  gap: 8rpx;
  min-width: 0;
}

.toolbar .btn {
  width: 100%;
  min-width: 0;
  height: 64rpx;
  line-height: 64rpx;
  padding-left: 6rpx;
  padding-right: 6rpx;
  box-sizing: border-box;
  font-size: 24rpx;
  border-radius: 10rpx;
  gap: 6rpx;
  white-space: nowrap;
}

.toolbar .btn-icon {
  width: 28rpx;
  height: 28rpx;
  font-size: 20rpx;
  line-height: 28rpx;
}

.btn-disabled {
  opacity: 0.5;
}

.page-tabs {
  position: sticky;
  top: 0;
  z-index: 120;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6rpx;
  padding: 6rpx;
  margin-bottom: 0;
  border-radius: 12rpx;
  background: #edf0f5;
  box-sizing: border-box;
  box-shadow: 0 10rpx 18rpx rgba(247, 248, 250, 0.96);
}

.page-tab {
  min-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  color: #646a73;
  font-size: 25rpx;
  font-weight: 700;
  text-align: center;
  line-height: 32rpx;
  padding: 0 12rpx;
  box-sizing: border-box;
}

.page-tab.active {
  background: #ffffff;
  color: #07c160;
  box-shadow: 0 6rpx 18rpx rgba(31, 35, 41, 0.08);
}

.record-period {
  display: grid;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.period-seg {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  background: #ffffff;
  border: 1rpx solid #edf0f5;
  border-radius: 999rpx;
  padding: 4rpx;
}

.period-seg-item {
  min-height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  border-radius: 999rpx;
  color: #646a73;
  font-size: 26rpx;
  font-weight: 700;
}

.period-seg-item.active {
  background: #07c160;
  color: #ffffff;
}

.record-range-switch {
  width: 100%;
  min-height: 72rpx;
  display: grid;
  grid-template-columns: 64rpx minmax(0, 1fr) 64rpx;
  align-items: center;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(31, 35, 41, 0.05);
  padding: 0 8rpx;
  box-sizing: border-box;
}

.record-range-arrow {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: transparent;
  color: #07c160;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 56rpx;
  border: 0;
  box-shadow: none;
  padding: 0;
  margin: 0;
}

.record-range-arrow::after {
  border: 0;
}

.record-range-current {
  min-width: 0;
  color: #1f2329;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 36rpx;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.record-list {
  display: grid;
  gap: 14rpx;
}

.record-list .empty-card,
.record-list .record-card {
  background: #ffffff;
  border: 1rpx solid #edf0f5;
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 41, 0.04);
}

.record-list .empty-card {
  color: #8a8f99;
}

.record-list .record-card {
  min-height: 112rpx;
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.record-main {
  color: #1f2329;
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 6rpx;
}

.record-time {
  color: #646a73;
  font-size: 24rpx;
  line-height: 36rpx;
  text-align: right;
  flex-shrink: 0;
}

.mine-tag {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  border-radius: 8rpx;
  padding: 0 16rpx;
  background: #e8f8ef;
  color: #07c160;
  font-size: 24rpx;
  margin-top: 10rpx;
}

.empty-state {
  background: #ffffff;
  border: 1rpx solid #edf0f5;
  border-radius: 16rpx;
  padding: 28rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.guard-btn {
  margin-top: 20rpx;
}

.schedule-list {
  display: grid;
  gap: 18rpx;
}

.day-card {
  border: 1rpx solid #edf0f5;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 41, 0.04);
  overflow: hidden;
}

.weekend-card {
  background: #fcfdff;
}

.day-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid #f2f3f5;
}

.date-badge {
  width: 72rpx;
  min-height: 72rpx;
  display: grid;
  align-content: center;
  justify-items: center;
  flex-shrink: 0;
  border-radius: 16rpx;
  background: #f2f7ff;
}

.date-main {
  color: #1677ff;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 34rpx;
}

.date-week {
  color: #5f8fd9;
  font-size: 20rpx;
  line-height: 26rpx;
}

.day-title {
  min-width: 0;
  flex: 1;
}

.day-date {
  color: #1f2329;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 38rpx;
}

.day-summary {
  color: #8a8f99;
  font-size: 23rpx;
  line-height: 32rpx;
  margin-top: 2rpx;
}

.shift-list {
  display: grid;
  gap: 0;
}

.shift-card {
  position: relative;
  display: flex;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-top: 1rpx solid #f7f8fa;
  box-sizing: border-box;
}

.shift-card:first-child {
  border-top: 0;
}

.shift-color {
  width: 10rpx;
  align-self: stretch;
  min-height: 76rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}

.shift-main {
  min-width: 0;
  flex: 1;
}

.shift-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.shift-title-row > view:first-child {
  min-width: 0;
  flex: 1;
}

.shift-name {
  color: #1f2329;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 40rpx;
}

.shift-time {
  color: #8a8f99;
  font-size: 23rpx;
  line-height: 32rpx;
  margin-top: 2rpx;
}

.people {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 14rpx;
}

.person,
.empty {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  border-radius: 999rpx;
  padding: 0 14rpx;
  font-size: 24rpx;
}

.person-wrap {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.person {
  background: #f7f8fa;
  color: #1f2329;
  border: 1rpx solid #edf0f5;
}

.person-tag {
  display: inline-flex;
  align-items: center;
  min-height: 32rpx;
  border-radius: 999rpx;
  padding: 0 10rpx;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 32rpx;
}

.person-tag.checked {
  background: #e8f8ef;
  color: #07c160;
}

.person-tag.absent {
  background: #fdecec;
  color: #e64340;
}

.empty {
  color: #8a8f99;
}

.cell-btn {
  width: 112rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin: 0;
  border-radius: 999rpx;
  background: #e8f8ef;
  color: #07c160;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 44rpx;
  box-sizing: border-box;
}

.sheet-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(31, 35, 41, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.sheet {
  width: 86vw;
  max-width: 600rpx;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-sizing: border-box;
}

.sheet-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid #edf0f5;
  flex-shrink: 0;
}

.sheet-head .sheet-close {
  width: auto;
  height: auto;
  min-width: 0;
  background: transparent;
  color: #8a8f99;
  font-size: 44rpx;
  font-weight: 400;
  line-height: 1;
  flex-shrink: 0;
  align-self: flex-start;
  padding: 0;
  margin: 0;
}

.sheet-head > view:first-child {
  min-width: 0;
  flex: 1;
}

.sheet-title {
  color: #1f2329;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 46rpx;
}

.sheet-subtitle {
  margin-top: 6rpx;
  font-size: 26rpx;
  line-height: 36rpx;
}

.sheet-close {
  width: 54rpx;
  height: 54rpx;
  min-width: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f2f3f5;
  color: #646a73;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 54rpx;
  padding: 0;
  margin: 0;
  box-shadow: none;
}

.sheet-close::after {
  border: 0;
}

.staff-options {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
}

.staff-option {
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-bottom: 1rpx solid #edf0f5;
}

.staff-name {
  color: #1f2329;
  font-weight: 700;
  line-height: 38rpx;
}

.sheet-actions {
  flex-shrink: 0;
  padding-top: 20rpx;
}

.check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 999rpx;
  text-align: center;
  line-height: 48rpx;
  color: #8a8f99;
  background: #f2f3f5;
  font-size: 28rpx;
  font-weight: 800;
}

.checked {
  color: #ffffff;
  background: #07c160;
}

.print-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(31, 35, 41, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1100;
}

.print-sheet {
  width: 92vw;
  max-width: 640rpx;
  max-height: 86vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-sizing: border-box;
}

.print-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid #edf0f5;
  flex-shrink: 0;
}

.print-head .sheet-close {
  width: auto;
  height: auto;
  min-width: 0;
  background: transparent;
  color: #8a8f99;
  font-size: 44rpx;
  font-weight: 400;
  line-height: 1;
  flex-shrink: 0;
  align-self: flex-start;
  padding: 0;
  margin: 0;
}

.print-head > view:first-child {
  min-width: 0;
  flex: 1;
}

.print-title {
  color: #1f2329;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 46rpx;
}

.print-subtitle {
  margin-top: 6rpx;
  font-size: 26rpx;
  line-height: 36rpx;
}

.print-canvas-wrap {
  position: relative;
  flex: 1;
  min-height: 0;
  margin: 20rpx 0;
  border: 1rpx solid #edf0f5;
  border-radius: 12rpx;
  background: #f7f8fa;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.print-canvas {
  position: absolute;
  left: -9999px;
  top: -9999px;
  width: 1123px;
  height: 794px;
}

.print-preview {
  max-width: 100%;
  max-height: 100%;
  width: auto;
  height: auto;
  display: block;
}

.print-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  flex-shrink: 0;
}

.print-actions .btn {
  width: 100%;
  min-width: 0;
}

.print-tip {
  margin-top: 14rpx;
  font-size: 23rpx;
  line-height: 32rpx;
  text-align: center;
}
