<view class="page schedule-page">
  <view class="topbar">
    <view class="topbar-main">
      <view class="title">{{monthText}}</view>
      <view class="topbar-desc">{{canManage ? '管理端：查看和调整门店班次安排' : '员工端：查看本门店与我的班次'}}</view>
      <view wx:if="{{role === 'employee'}}" class="mine-tag">当前员工：{{currentStaffName || '未选择'}} · 本门店排班</view>
    </view>
    <view class="month-switch">
      <button class="month-arrow" bindtap="prevMonth">‹</button>
      <view class="month-current">{{monthShortText}}</view>
      <button class="month-arrow" bindtap="nextMonth">›</button>
    </view>
  </view>

  <view wx:if="{{canManage}}" class="toolbar">
    <button class="btn btn-primary" bindtap="autoSchedule"><text class="btn-icon">+</text>生成本月班表</button>
    <button class="btn btn-ghost" bindtap="clearMonth"><text class="btn-icon">×</text>清空</button>
  </view>

  <view wx:if="{{role === 'employee' && !employeeReady}}" class="empty-state">
    <view class="section-title">请先完成员工登录</view>
    <view class="muted">需要授权头像昵称和手机号后，才能查看个人班次。</view>
    <navigator class="btn btn-primary guard-btn" url="/pages/home/home" open-type="switchTab"><text class="btn-icon">←</text>回到工作台</navigator>
  </view>

  <view wx:elif="{{role === 'employee' && !rows.length}}" class="empty-state">
    <view class="section-title">本月暂无我的班次</view>
    <view class="muted">本门店本月暂无排班，或请让店长生成本月安排。</view>
  </view>

  <view wx:if="{{employeeReady}}" class="schedule-list">
    <view wx:for="{{rows}}" wx:key="date" class="day-card {{item.isWeekend ? 'weekend-card' : ''}}">
      <view class="day-head">
        <view class="date-badge">
          <view class="date-main">{{item.day}}</view>
          <view class="date-week">{{item.week}}</view>
        </view>
        <view class="day-title">
          <view class="day-date">{{item.date}}</view>
          <view class="day-summary">{{item.hasStoreSchedule ? '已排班' : '暂无安排'}}</view>
        </view>
      </view>

      <view class="shift-list">
        <view wx:for="{{item.shifts}}" wx:for-item="shift" wx:key="id" class="shift-card">
          <view class="shift-color" style="background: {{shift.color}}"></view>
          <view class="shift-main">
            <view class="shift-title-row">
              <view>
                <view class="shift-name">{{shift.name}}</view>
                <view class="shift-time">{{shift.time}}</view>
              </view>
              <button wx:if="{{canManage}}" class="cell-btn" data-date="{{item.date}}" data-shift="{{shift.id}}" bindtap="openPicker">调整</button>
            </view>
            <view class="people">
              <text wx:if="{{!shift.names.length}}" class="empty">未排</text>
              <text wx:for="{{shift.names}}" wx:for-item="name" wx:key="*this" class="person">{{name}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{pickerVisible}}" class="sheet-mask" bindtap="closePicker">
    <view class="sheet" catchtap="noop">
      <view class="sheet-head">
        <view>
          <view class="sheet-title">选择伙伴</view>
          <view class="muted sheet-subtitle">{{activeDate}} · {{activeShiftName}}</view>
        </view>
        <button class="sheet-close" bindtap="closePicker">×</button>
      </view>
      <view class="staff-options">
        <view wx:for="{{staffOptions}}" wx:key="id" class="staff-option" data-id="{{item.id}}" bindtap="toggleStaff">
          <view>
            <view class="staff-name">{{item.name}}</view>
            <view class="muted">{{item.role}}</view>
          </view>
          <view class="check {{item.checked ? 'checked' : ''}}">{{item.checked ? '✓' : '+'}}</view>
        </view>
      </view>
      <view class="sheet-actions">
        <button class="btn btn-primary" bindtap="savePicker"><text class="btn-icon">✓</text>保存</button>
      </view>
    </view>
  </view>
</view>
