<view class="page schedule-page">
  <view class="workbench-back-icon" bindtap="goWorkbench">‹</view>

  <view wx:if="{{canManage}}" class="page-tabs">
    <view class="page-tab {{activeTab === 'schedule' ? 'active' : ''}}" data-tab="schedule" bindtap="switchTab">班表</view>
    <view class="page-tab {{activeTab === 'records' ? 'active' : ''}}" data-tab="records" bindtap="switchTab">打卡记录</view>
  </view>

  <block wx:if="{{activeTab === 'records'}}">
    <view class="record-period">
      <view class="period-seg">
        <view class="period-seg-item {{recordPeriod === 'day' ? 'active' : ''}}" data-period="day" bindtap="switchRecordPeriod">日</view>
        <view class="period-seg-item {{recordPeriod === 'week' ? 'active' : ''}}" data-period="week" bindtap="switchRecordPeriod">周</view>
        <view class="period-seg-item {{recordPeriod === 'month' ? 'active' : ''}}" data-period="month" bindtap="switchRecordPeriod">月</view>
      </view>
      <view class="record-range-switch">
        <view class="record-range-arrow" bindtap="prevRecordRange">‹</view>
        <view class="record-range-current">{{recordRangeText}}</view>
        <view class="record-range-arrow" bindtap="nextRecordRange">›</view>
      </view>
    </view>

    <view class="record-list">
      <view wx:if="{{!recordList.length}}" class="empty-card">{{recordEmptyText}}</view>
      <view wx:for="{{recordList}}" wx:key="id" class="record-card">
        <view>
          <view class="record-main">{{item.staffName}} · {{item.shiftName}}</view>
          <view class="muted">{{item.storeName}} · {{item.date}}</view>
        </view>
        <view class="record-time">
          <view>上班：{{item.clockIn || '-'}}</view>
          <view>下班：{{item.clockOut || '-'}}</view>
        </view>
      </view>
    </view>
  </block>

  <block wx:else>
  <view class="schedule-tools {{canManage ? 'manage' : 'employee'}}">
    <view class="month-switch">
      <button class="month-arrow" bindtap="prevMonth">‹</button>
      <view class="month-current">{{monthShortText}}</view>
      <button class="month-arrow" bindtap="nextMonth">›</button>
    </view>
    <view wx:if="{{role === 'employee'}}" class="mine-tag">当前员工：{{currentStaffName || '未选择'}} · 本门店排班</view>
    <view wx:if="{{canManage}}" class="toolbar">
      <button class="btn btn-primary auto-schedule-btn {{!canAutoSchedule ? 'btn-disabled' : ''}}" disabled="{{!canAutoSchedule}}" bindtap="autoSchedule">生成班表</button>
      <button class="btn btn-ghost" bindtap="printSchedule"><text class="btn-icon">🖨</text>打印</button>
      <button class="btn btn-ghost" bindtap="clearMonth"><text class="btn-icon">×</text>清空</button>
    </view>
  </view>

  <view wx:if="{{role === 'employee' && !employeeReady}}" class="empty-state">
    <view class="section-title">请先完成员工登录</view>
    <view class="muted">需要授权头像昵称和手机号后，才能查看个人班次。</view>
    <navigator class="btn btn-primary guard-btn" url="/pages/home/home" open-type="switchTab"><text class="btn-icon">←</text>回到工作台</navigator>
  </view>

  <view wx:elif="{{role === 'employee' && !rows.length}}" class="empty-state">
    <view class="section-title">本月暂无我的班次</view>
    <view class="muted">本门店本月暂无排班，或请让店长生成本月安排。</view>
  </view>

  <view wx:if="{{employeeReady}}" class="schedule-list">
    <view wx:for="{{rows}}" wx:key="date" class="day-card {{item.isWeekend ? 'weekend-card' : ''}}">
      <view class="day-head">
        <view class="date-badge">
          <view class="date-main">{{item.day}}</view>
          <view class="date-week">{{item.week}}</view>
        </view>
        <view class="day-title">
          <view class="day-date">{{item.date}}</view>
          <view class="day-summary">{{item.hasStoreSchedule ? '已排班' : '暂无安排'}}</view>
        </view>
      </view>

      <view class="shift-list">
        <view wx:for="{{item.shifts}}" wx:for-item="shift" wx:key="id" class="shift-card">
          <view class="shift-color" style="background: {{shift.color}}"></view>
          <view class="shift-main">
            <view class="shift-title-row">
              <view>
                <view class="shift-name">{{shift.name}}</view>
                <view class="shift-time">{{shift.time}}</view>
              </view>
              <view wx:if="{{canManage}}" class="cell-btn" data-date="{{item.date}}" data-shift="{{shift.id}}" bindtap="openPicker">调整</view>
            </view>
            <view class="people">
              <text wx:if="{{!shift.nameItems.length}}" class="empty">未排</text>
              <view wx:for="{{shift.nameItems}}" wx:for-item="person" wx:key="id" class="person-wrap">
                <text class="person">{{person.name}}</text>
                <text wx:if="{{person.status === 'checkedIn'}}" class="person-tag checked">已打卡</text>
                <text wx:if="{{person.status === 'absent'}}" class="person-tag absent">缺勤</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{pickerVisible}}" class="sheet-mask" bindtap="closePicker">
    <view class="sheet" catchtap="noop">
      <view class="sheet-head">
        <view>
          <view class="sheet-title">选择伙伴</view>
          <view class="muted sheet-subtitle">{{activeDate}} · {{activeShiftName}}</view>
        </view>
        <button class="sheet-close" bindtap="closePicker">×</button>
      </view>
      <view class="staff-options">
        <view wx:for="{{staffOptions}}" wx:key="id" class="staff-option" data-id="{{item.id}}" bindtap="toggleStaff">
          <view>
            <view class="staff-name">{{item.name}}</view>
            <view class="muted">{{item.role}}</view>
          </view>
          <view class="check {{item.checked ? 'checked' : ''}}">{{item.checked ? '✓' : '+'}}</view>
        </view>
      </view>
      <view class="sheet-actions">
        <button class="btn btn-primary" bindtap="savePicker"><text class="btn-icon">✓</text>保存</button>
      </view>
    </view>
  </view>

  <view wx:if="{{printVisible}}" class="print-mask" catchtap="closePrint">
    <view class="print-sheet" catchtap="noop">
      <view class="print-head">
        <view>
          <view class="print-title">A4 横排班表预览</view>
          <view class="muted print-subtitle">{{monthText}} · {{currentStoreName}}</view>
        </view>
        <button class="sheet-close" bindtap="closePrint">×</button>
      </view>
      <view class="print-canvas-wrap">
        <canvas
          type="2d"
          id="printCanvas"
          class="print-canvas"
          style="width: 1123px; height: 794px;"
        ></canvas>
        <image wx:if="{{printTempPath}}" class="print-preview" src="{{printTempPath}}" mode="aspectFit" show-menu-by-longpress></image>
      </view>
      <view class="print-actions">
        <button class="btn btn-ghost" bindtap="previewPrintImage">查看大图</button>
        <button class="btn btn-primary" bindtap="savePrintImage" loading="{{printSaving}}"><text class="btn-icon">⬇</text>保存到相册</button>
      </view>
      <view class="muted print-tip">保存到相册后，可在打印店或办公室打印机打印为 A4 横向纸张。</view>
    </view>
  </view>
  </block>
</view>
