<view class="page" bindtap="closeDropdowns">
  <view wx:if="{{!canManage}}" class="panel guard-panel">
    <view class="section-title">员工端无需维护人员</view>
    <view class="muted">如需新增或删除员工，请切换到管理端。</view>
    <navigator class="btn btn-primary guard-btn" url="/pages/home/home" open-type="switchTab"><text class="btn-icon">←</text>回到工作台</navigator>
  </view>

  <view wx:if="{{canManage}}" class="staff-menu">
    <view class="staff-menu-item {{activeStaffMenu === 'onboard' ? 'active' : ''}}" data-menu="onboard" bindtap="switchStaffMenu">办理员工入职</view>
    <view class="staff-menu-item {{activeStaffMenu === 'list' ? 'active' : ''}}" data-menu="list" bindtap="switchStaffMenu">查看本店员工信息</view>
  </view>

  <view wx:if="{{canManage && activeStaffMenu === 'onboard'}}" class="section-label">入职</view>
  <view wx:if="{{canManage && activeStaffMenu === 'onboard'}}" class="panel add-panel">
    <view>
      <view class="section-title">{{editingStaffId ? '编辑员工' : '办理入职'}}</view>
      <view wx:if="{{editingStaffId}}" class="muted">修改后点击保存更新员工资料</view>
      <view wx:else class="muted">新增员工默认归属：{{currentStoreName || '当前门店'}}</view>
    </view>
    <view class="form-group list-panel">
      <input class="input form-input" placeholder="姓名" value="{{form.name}}" data-field="name" bindinput="onInput" />
      <view class="dropdown-field">
        <view class="select-box form-select" data-dropdown="gender" catchtap="toggleDropdown">{{form.gender || '性别'}}</view>
        <view wx:if="{{activeDropdown === 'gender'}}" class="dropdown-menu">
          <view wx:for="{{genderOptions}}" wx:key="value" class="dropdown-option" data-field="gender" data-value="{{item.value}}" data-label="{{item.label}}" catchtap="selectDropdownOption">{{item.label}}</view>
        </view>
      </view>
      <input class="input form-input" type="idcard" maxlength="18" placeholder="身份证号" value="{{form.idCard}}" data-field="idCard" bindinput="onInput" bindblur="calcAgeFromIdCard" />
      <input class="input form-input" type="number" placeholder="年龄" value="{{form.age}}" data-field="age" bindinput="onInput" />
      <view class="dropdown-field">
        <view class="select-box form-select" data-dropdown="position" catchtap="toggleDropdown">职位：{{form.role || '店长/收银/网管'}}</view>
        <view wx:if="{{activeDropdown === 'position'}}" class="dropdown-menu">
          <view wx:for="{{positionOptions}}" wx:key="value" class="dropdown-option" data-field="position" data-value="{{item.value}}" data-label="{{item.label}}" catchtap="selectDropdownOption">{{item.label}}</view>
        </view>
      </view>
      <input class="input form-input" type="number" placeholder="手机号" value="{{form.phone}}" data-field="phone" bindinput="onInput" />
      <picker mode="date" value="{{form.hireDate}}" bindchange="selectHireDate">
        <view class="select-box form-select date-select">入职时间：{{form.hireDate}}</view>
      </picker>
      <input class="input form-input" type="number" placeholder="每周最多班次数" value="{{form.maxPerWeek}}" data-field="maxPerWeek" bindinput="onInput" />
    </view>
    <view class="form-actions">
      <button class="btn btn-primary" bindtap="saveStaff"><text class="btn-icon">✓</text>保存</button>
      <button wx:if="{{editingStaffId}}" class="btn btn-ghost" bindtap="cancelEdit">取消编辑</button>
    </view>
  </view>

  <view wx:if="{{canManage && activeStaffMenu === 'list'}}" class="section-label">员工</view>
  <view wx:if="{{canManage && activeStaffMenu === 'list'}}" class="staff-search">
    <text class="search-icon">⌕</text>
    <input class="staff-search-input" value="{{staffSearchKeyword}}" placeholder="搜索姓名、手机号、身份证号" bindinput="onStaffSearchInput" />
    <button wx:if="{{staffSearchKeyword}}" class="search-clear" bindtap="clearStaffSearch">×</button>
  </view>
  <view wx:if="{{canManage && activeStaffMenu === 'list'}}" class="staff-list">
    <view wx:for="{{staff}}" wx:key="id" class="staff-card">
      <view class="staff-card-header">
        <view class="staff-avatar">
          <image wx:if="{{item.avatarUrl}}" class="staff-avatar-img" src="{{item.avatarUrl}}" mode="aspectFill" />
          <text wx:else>{{item.nameInitial}}</text>
        </view>
        <view class="staff-title">
          <view class="staff-name">{{item.name}}</view>
          <view class="staff-subtitle">{{item.role}} · {{item.gender || '性别未填'}} · {{item.age || '年龄未填'}}岁</view>
        </view>
        <view class="status-badge {{item.status === 'left' ? 'danger' : (item.openidBound ? 'success' : 'warning')}}">{{item.statusText}}</view>
      </view>

      <view class="staff-info-grid">
        <view class="staff-info-item">
          <text class="info-label">身份</text>
          <text class="info-value">{{item.systemRoleText}}</text>
        </view>
        <view class="staff-info-item">
          <text class="info-label">手机</text>
          <text class="info-value">{{item.phone || '未填'}}</text>
        </view>
        <view class="staff-info-item">
          <text class="info-label">门店</text>
          <text class="info-value">{{item.storeNames}}</text>
        </view>
        <view class="staff-info-item">
          <text class="info-label">上限</text>
          <text class="info-value">每周 {{item.maxPerWeek}} 班</text>
        </view>
        <view class="staff-info-item full">
          <text class="info-label">身份证</text>
          <text class="info-value">{{item.idCard || '未填'}}</text>
        </view>
        <view class="staff-info-item">
          <text class="info-label">入职</text>
          <text class="info-value">{{item.hireDate || '未填'}}</text>
        </view>
        <view class="staff-info-item">
          <text class="info-label">入职码</text>
          <text class="info-value invite-value">{{item.inviteCode}}</text>
        </view>
        <view wx:if="{{item.canViewPassword}}" class="staff-info-item full">
          <text class="info-label">登录密码</text>
          <view class="password-value-row">
            <text class="info-value password-value">{{item.passwordVisible ? item.loginPassword : '••••••'}}</text>
            <view class="password-toggle" data-id="{{item.id}}" catchtap="togglePasswordVisible">{{item.passwordVisible ? '隐藏' : '显示'}}</view>
          </view>
        </view>
      </view>

      <view class="staff-actions">
        <button class="staff-action-btn edit-btn" data-id="{{item.id}}" bindtap="startEdit">编辑</button>
        <button wx:if="{{item.status !== 'left'}}" class="staff-action-btn leave-btn" data-id="{{item.id}}" bindtap="markLeft">离职</button>
        <button wx:else class="staff-action-btn delete-text-btn" data-id="{{item.id}}" bindtap="deleteStaff">删除</button>
      </view>
    </view>
    <view wx:if="{{!staff.length}}" class="empty-staff">本店暂无员工</view>
  </view>
</view>
