.add-panel {
  display: grid;
  gap: 20rpx;
}

.guard-panel {
  display: grid;
  gap: 16rpx;
}

.guard-btn {
  margin-top: 8rpx;
}

.staff-menu {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
  padding: 8rpx;
  margin-bottom: 22rpx;
  border-radius: 12rpx;
  background: #edf0f5;
  box-sizing: border-box;
}

.staff-menu-item {
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  color: #646a73;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
  line-height: 34rpx;
  padding: 0 12rpx;
  box-sizing: border-box;
}

.staff-menu-item.active {
  background: #ffffff;
  color: #07c160;
  box-shadow: 0 6rpx 18rpx rgba(31, 35, 41, 0.08);
}

.store-scope-panel {
  padding: 24rpx;
  margin-bottom: 22rpx;
}

.form-group {
  display: grid;
  box-shadow: none;
  overflow: visible;
}

.form-input {
  min-height: 92rpx;
  border: 0;
  border-bottom: 1rpx solid #edf0f5;
  border-radius: 0;
  background: transparent;
}

.form-input:last-child {
  border-bottom: 0;
}

.dropdown-field {
  position: relative;
  min-height: 92rpx;
  background: #ffffff;
}

.select-box {
  min-height: 92rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-sizing: border-box;
  color: #1f2329;
  border-bottom: 1rpx solid #edf0f5;
}

.form-select {
  justify-content: space-between;
  color: #8a8f99;
}

.date-select {
  color: #1f2329;
}

.form-select::after {
  content: "";
  width: 14rpx;
  height: 14rpx;
  border-right: 3rpx solid #c9cdd4;
  border-bottom: 3rpx solid #c9cdd4;
  transform: rotate(45deg);
  margin-left: 16rpx;
  margin-bottom: 8rpx;
  flex-shrink: 0;
}

.dropdown-menu {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  top: 84rpx;
  z-index: 50;
  border: 1rpx solid #e5e6eb;
  border-radius: 10rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(31, 35, 41, 0.12);
  overflow: hidden;
}

.dropdown-option {
  min-height: 82rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  color: #1f2329;
  font-size: 28rpx;
  border-bottom: 1rpx solid #edf0f5;
  box-sizing: border-box;
}

.dropdown-option:last-child {
  border-bottom: 0;
}

.form-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
}

.staff-list {
  display: block;
}

.staff-card {
  min-height: 116rpx;
  background: transparent;
  border-bottom: 1rpx solid #edf0f5;
  padding: 26rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  box-shadow: none;
}

.staff-card:last-child {
  border-bottom: 0;
}

.staff-name {
  color: #1f2329;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.staff-card .muted {
  line-height: 36rpx;
}

.invite-line {
  color: #07c160;
  font-size: 24rpx;
  line-height: 36rpx;
  margin-top: 4rpx;
}

.staff-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 12rpx;
  flex-shrink: 0;
}

.edit-btn,
.leave-btn,
.delete-text-btn {
  min-width: 96rpx;
  height: 56rpx;
  border-radius: 8rpx;
  border: 0;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 56rpx;
  padding: 0 18rpx;
  margin: 0;
  box-shadow: none;
}

.edit-btn {
  background: #f2f3f5;
  color: #1f2329;
}

.leave-btn {
  background: #fff7e6;
  color: #b76e00;
}

.delete-text-btn {
  background: #fff2f0;
  color: #e64340;
}

.delete-btn,
.restore-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: #fff2f0;
  color: #e64340;
  border: 0;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 56rpx;
  padding: 0;
  flex-shrink: 0;
  box-shadow: none;
}

.delete-btn::after,
.restore-btn::after,
.edit-btn::after,
.leave-btn::after,
.delete-text-btn::after {
  border: 0;
}

.restore-btn {
  background: #e8f8ef;
  color: #07c160;
  box-shadow: none;
}

.empty-staff {
  min-height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8a8f99;
  font-size: 26rpx;
}
