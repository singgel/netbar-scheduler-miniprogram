.add-panel {
  display: grid;
  gap: 20rpx;
}

.guard-panel {
  display: grid;
  gap: 16rpx;
}

.guard-btn {
  margin-top: 8rpx;
}

.form-group {
  display: grid;
  box-shadow: none;
}

.form-input {
  min-height: 92rpx;
  border: 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
  border-radius: 0;
  background: transparent;
}

.form-input:last-child {
  border-bottom: 0;
}

.staff-list {
  display: block;
}

.staff-card {
  min-height: 116rpx;
  background: transparent;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
  padding: 26rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  box-shadow: none;
}

.staff-card:last-child {
  border-bottom: 0;
}

.staff-name {
  color: #1d1d1f;
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 6rpx;
}

.staff-card .muted {
  line-height: 36rpx;
}

.invite-line {
  color: #111111;
  font-size: 24rpx;
  line-height: 36rpx;
  margin-top: 4rpx;
}

.delete-btn,
.restore-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: #fff1f2;
  color: #be123c;
  border: 0;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 56rpx;
  padding: 0;
  flex-shrink: 0;
  box-shadow: inset 0 0 0 1rpx rgba(190, 18, 60, 0.12);
}

.delete-btn::after,
.restore-btn::after {
  border: 0;
}

.restore-btn {
  background: #f5f5f7;
  color: #111111;
  box-shadow: inset 0 0 0 1rpx rgba(0, 0, 0, 0.08);
}
