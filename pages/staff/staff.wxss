.add-panel {
  display: grid;
  gap: 20rpx;
}

.guard-panel {
  display: grid;
  gap: 16rpx;
}

.guard-btn {
  margin-top: 8rpx;
}

.form-group {
  display: grid;
  box-shadow: none;
}

.form-input {
  min-height: 92rpx;
  border: 0;
  border-bottom: 1rpx solid #edf0f5;
  border-radius: 0;
  background: transparent;
}

.form-input:last-child {
  border-bottom: 0;
}

.staff-list {
  display: block;
}

.staff-card {
  min-height: 116rpx;
  background: transparent;
  border-bottom: 1rpx solid #edf0f5;
  padding: 26rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  box-shadow: none;
}

.staff-card:last-child {
  border-bottom: 0;
}

.staff-name {
  color: #1f2329;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.staff-card .muted {
  line-height: 36rpx;
}

.invite-line {
  color: #07c160;
  font-size: 24rpx;
  line-height: 36rpx;
  margin-top: 4rpx;
}

.delete-btn,
.restore-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: #fff2f0;
  color: #e64340;
  border: 0;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 56rpx;
  padding: 0;
  flex-shrink: 0;
  box-shadow: none;
}

.delete-btn::after,
.restore-btn::after {
  border: 0;
}

.restore-btn {
  background: #e8f8ef;
  color: #07c160;
  box-shadow: none;
}
