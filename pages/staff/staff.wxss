.add-panel {
  display: grid;
  gap: 20rpx;
}

.guard-panel {
  display: grid;
  gap: 16rpx;
}

.guard-btn {
  margin-top: 8rpx;
}

.staff-menu {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6rpx;
  padding: 6rpx;
  margin-bottom: 18rpx;
  border-radius: 12rpx;
  background: #edf0f5;
  box-sizing: border-box;
}

.staff-menu-item {
  min-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  color: #646a73;
  font-size: 25rpx;
  font-weight: 700;
  text-align: center;
  line-height: 32rpx;
  padding: 0 12rpx;
  box-sizing: border-box;
}

.staff-menu-item.active {
  background: #ffffff;
  color: #07c160;
  box-shadow: 0 6rpx 18rpx rgba(31, 35, 41, 0.08);
}

.form-group {
  display: grid;
  box-shadow: none;
  overflow: visible;
}

.form-input {
  min-height: 92rpx;
  border: 0;
  border-bottom: 1rpx solid #edf0f5;
  border-radius: 0;
  background: transparent;
}

.form-input:last-child {
  border-bottom: 0;
}

.dropdown-field {
  position: relative;
  min-height: 92rpx;
  background: #ffffff;
}

.select-box {
  min-height: 92rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-sizing: border-box;
  color: #1f2329;
  border-bottom: 1rpx solid #edf0f5;
}

.form-select {
  justify-content: space-between;
  color: #8a8f99;
}

.date-select {
  color: #1f2329;
}

.form-select::after {
  content: "";
  width: 14rpx;
  height: 14rpx;
  border-right: 3rpx solid #c9cdd4;
  border-bottom: 3rpx solid #c9cdd4;
  transform: rotate(45deg);
  margin-left: 16rpx;
  margin-bottom: 8rpx;
  flex-shrink: 0;
}

.dropdown-menu {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  top: 84rpx;
  z-index: 50;
  border: 1rpx solid #e5e6eb;
  border-radius: 10rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(31, 35, 41, 0.12);
  overflow: hidden;
}

.dropdown-option {
  min-height: 82rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  color: #1f2329;
  font-size: 28rpx;
  border-bottom: 1rpx solid #edf0f5;
  box-sizing: border-box;
}

.dropdown-option:last-child {
  border-bottom: 0;
}

.form-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
}

.staff-search {
  height: 72rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  padding: 0 20rpx;
  border: 1rpx solid #edf0f5;
  border-radius: 14rpx;
  background: #ffffff;
  box-sizing: border-box;
  box-shadow: 0 6rpx 18rpx rgba(31, 35, 41, 0.035);
}

.search-icon {
  color: #8a8f99;
  font-size: 30rpx;
  line-height: 1;
  flex-shrink: 0;
}

.staff-search-input {
  min-width: 0;
  flex: 1;
  height: 70rpx;
  color: #1f2329;
  font-size: 25rpx;
}

.search-clear {
  width: 44rpx;
  height: 44rpx;
  border-radius: 999rpx;
  background: #f2f3f5;
  color: #8a8f99;
  font-size: 30rpx;
  line-height: 42rpx;
  padding: 0;
  margin: 0;
  border: 0;
  box-shadow: none;
  flex-shrink: 0;
}

.search-clear::after {
  border: 0;
}

.staff-list {
  display: grid;
  gap: 16rpx;
}

.staff-card {
  background: #ffffff;
  border: 1rpx solid #edf0f5;
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 41, 0.04);
  overflow: hidden;
}

.staff-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.staff-avatar,
.staff-avatar-img {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 50%;
  overflow: hidden;
  box-sizing: border-box;
}

.staff-avatar {
  background: #e8f8ef;
  color: #07c160;
  font-size: 28rpx;
  font-weight: 800;
}

.staff-avatar-img {
  background: #f2f3f5;
}

.staff-title {
  min-width: 0;
  flex: 1;
}

.staff-name {
  color: #1f2329;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 44rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.staff-subtitle {
  color: #646a73;
  font-size: 24rpx;
  line-height: 34rpx;
  margin-top: 4rpx;
}

.status-badge {
  min-width: 92rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 999rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.status-badge.success {
  background: #e8f8ef;
  color: #07c160;
}

.status-badge.warning {
  background: #fff7e6;
  color: #b76e00;
}

.status-badge.danger {
  background: #fff2f0;
  color: #e64340;
}

.staff-info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  column-gap: 18rpx;
  row-gap: 12rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid #f2f3f5;
  border-bottom: 1rpx solid #f2f3f5;
}

.staff-info-item {
  min-width: 0;
  display: grid;
  gap: 4rpx;
}

.staff-info-item.full {
  grid-column: 1 / -1;
}

.info-label {
  color: #8a8f99;
  font-size: 21rpx;
  line-height: 28rpx;
}

.info-value {
  color: #343842;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 34rpx;
  word-break: break-all;
}

.invite-value {
  color: #07c160;
}

.password-value-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.password-value {
  font-family: monospace;
  letter-spacing: 2rpx;
}

.password-toggle {
  flex-shrink: 0;
  min-height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #e8f8ef;
  color: #07c160;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 40rpx;
}

.staff-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
  padding-top: 18rpx;
}

.staff-action-btn {
  min-width: 88rpx;
  height: 50rpx;
  border-radius: 999rpx;
  border: 0;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 50rpx;
  padding: 0 20rpx;
  margin: 0;
  box-shadow: none;
}

.edit-btn {
  background: #f2f3f5;
  color: #1f2329;
}

.leave-btn {
  background: #fff7e6;
  color: #b76e00;
}

.delete-text-btn {
  background: #fff2f0;
  color: #e64340;
}

.staff-action-btn::after {
  border: 0;
}

.empty-staff {
  min-height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8a8f99;
  font-size: 26rpx;
}
