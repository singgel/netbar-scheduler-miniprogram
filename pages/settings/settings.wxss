.tip {
  margin: 8rpx 0 12rpx;
}

.guard-panel {
  display: grid;
  gap: 16rpx;
}

.guard-btn {
  margin-top: 8rpx;
}

.settings-menu {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6rpx;
  padding: 6rpx;
  margin-bottom: 18rpx;
  border-radius: 12rpx;
  background: #edf0f5;
  box-sizing: border-box;
}

.settings-menu-item {
  min-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  color: #646a73;
  font-size: 25rpx;
  font-weight: 700;
  text-align: center;
  line-height: 32rpx;
  padding: 0 12rpx;
  box-sizing: border-box;
}

.settings-menu-item.active {
  background: #ffffff;
  color: #07c160;
  box-shadow: 0 6rpx 18rpx rgba(31, 35, 41, 0.08);
}

.shift-config {
  min-height: 126rpx;
  display: grid;
  gap: 12rpx;
  border-top: 1rpx solid #edf0f5;
  padding: 22rpx 0;
  box-sizing: border-box;
}

.config-panel {
  margin-top: 20rpx;
}

.shift-form {
  display: grid;
  gap: 14rpx;
  margin: 18rpx 0 14rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f7f8fa;
  box-sizing: border-box;
}

.shift-time-form {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.time-box {
  width: 100%;
  height: 76rpx;
  display: flex;
  align-items: center;
  padding: 0 22rpx;
  border: 1rpx solid #e5e6eb;
  border-radius: 8rpx;
  background: #ffffff;
  color: #1f2329;
  font-size: 26rpx;
  box-sizing: border-box;
}

.shift-add-btn {
  width: 100%;
  min-width: 0;
  height: 76rpx;
  line-height: 76rpx;
  padding-left: 12rpx;
  padding-right: 12rpx;
  margin: 0;
  box-sizing: border-box;
}

.shift-help {
  display: grid;
  gap: 4rpx;
  margin: 16rpx 0 4rpx;
  padding: 16rpx 18rpx;
  border-radius: 12rpx;
  background: #f7f8fa;
  box-sizing: border-box;
}

.help-main {
  color: #1f2329;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.help-sub {
  color: #8a8f99;
  font-size: 23rpx;
  line-height: 32rpx;
}

.store-form {
  display: grid;
  gap: 14rpx;
  margin-top: 18rpx;
}

.store-form .input,
.shift-form .input {
  width: 100%;
  min-width: 0;
}

.coord-grid,
.store-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.store-actions .btn {
  width: 100%;
  min-width: 0;
  padding-left: 12rpx;
  padding-right: 12rpx;
  box-sizing: border-box;
}

.store-list {
  margin-top: 22rpx;
  box-shadow: none;
}

.store-card {
  min-height: 0;
  border-bottom: 1rpx solid #edf0f5;
  padding: 24rpx;
  box-sizing: border-box;
  display: grid;
  gap: 18rpx;
}

.store-card:last-child {
  border-bottom: 0;
}

.store-name {
  color: #1f2329;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 40rpx;
  margin-bottom: 6rpx;
  word-break: break-all;
}

.store-info {
  min-width: 0;
}

.store-info .muted {
  display: block;
  font-size: 25rpx;
  line-height: 36rpx;
  word-break: break-all;
}

.store-card-actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 64rpx;
  align-items: center;
  gap: 16rpx;
}

.small-btn {
  width: 100%;
  min-width: 0;
  height: 56rpx;
  border-radius: 12rpx;
  background: #f2f3f5;
  color: #1f2329;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 56rpx;
  padding: 0 20rpx;
  margin: 0;
  box-shadow: none;
}

.small-btn::after {
  border: 0;
}

.active-store {
  background: #07c160;
  color: #ffffff;
}

.delete-store {
  width: 64rpx;
  height: 64rpx;
  min-width: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #fff2f0;
  color: #e64340;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 64rpx;
  box-sizing: border-box;
}

.shift-name {
  color: #1f2329;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 40rpx;
  white-space: nowrap;
}

.shift-row-body {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 190rpx;
  align-items: center;
  column-gap: 18rpx;
}

.shift-main {
  min-width: 0;
  flex: 1;
}

.shift-time-edit {
  width: 100%;
  display: grid;
  grid-template-columns: minmax(122rpx, 1fr) 28rpx minmax(122rpx, 1fr);
  align-items: center;
  gap: 10rpx;
}

.time-pill {
  width: 100%;
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  background: #f2f7ff;
  color: #1677ff;
  font-size: 24rpx;
  font-weight: 700;
  padding: 0 8rpx;
  box-sizing: border-box;
  white-space: nowrap;
}

.time-separator {
  color: #8a8f99;
  font-size: 22rpx;
  line-height: 54rpx;
  text-align: center;
}

.shift-controls {
  width: 190rpx;
  display: grid;
  grid-template-columns: 134rpx 44rpx;
  align-items: center;
  gap: 12rpx;
}

.stepper {
  width: 134rpx;
  height: 54rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid #e5e6eb;
  border-radius: 10rpx;
  overflow: hidden;
  background: #f7f8fa;
}

.step-btn {
  width: 40rpx;
  height: 54rpx;
  border-radius: 0;
  background: transparent;
  color: #07c160;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 54rpx;
  padding: 0;
  margin: 0;
}

.step-btn::after {
  border: 0;
}

.need {
  width: 54rpx;
  text-align: center;
  color: #1f2329;
  font-weight: 700;
  line-height: 54rpx;
}

.readonly-need {
  min-width: 88rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #f2f3f5;
  color: #646a73;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.delete-shift-btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #fff2f0;
  color: #e64340;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 44rpx;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
}
