<view class="page {{!isLoggedIn ? 'login-page' : ''}}">
  <block wx:if="{{!isLoggedIn}}">
    <view wx:if="{{autoLoggingIn}}" class="auto-login">
      <view class="brand">班次小助手</view>
      <view class="auto-title">正在登录</view>
      <view class="auto-subtitle">正在识别当前微信账号</view>
    </view>

    <view wx:else class="simple-login">
      <view class="brand">班次小助手</view>
      <view class="login-title">登录</view>
      <view class="login-copy">使用微信手机号授权识别超级管理员、店长或普通员工身份。</view>

      <view class="login-tabs">
        <view class="tab-btn {{loginMode === 'code' ? 'active' : ''}}" data-mode="code" bindtap="switchLoginMode">验证码</view>
        <view class="tab-btn {{loginMode === 'password' ? 'active' : ''}}" data-mode="password" bindtap="switchLoginMode">密码</view>
      </view>

      <view class="login-form">
        <input
          class="login-input"
          type="number"
          maxlength="11"
          placeholder="手机号"
          value="{{loginForm.phone}}"
          data-field="phone"
          bindinput="onLoginInput"
        />
        <view wx:if="{{loginMode === 'code'}}" class="credential-row">
          <input
            class="login-input credential-input"
            type="number"
            maxlength="6"
            placeholder="验证码"
            value="{{loginForm.credential}}"
            data-field="credential"
            bindinput="onLoginInput"
          />
          <view class="code-btn" bindtap="sendLoginCode">{{codeSent ? '重新获取验证码' : '获取验证码'}}</view>
        </view>
        <view wx:else class="credential-row password-mode">
          <input
            class="login-input credential-input"
            password="{{true}}"
            placeholder="密码"
            value="{{loginForm.credential}}"
            data-field="credential"
            bindinput="onLoginInput"
          />
        </view>
        <button class="login-primary" bindtap="loginWithForm">登录</button>
      </view>

      <button class="wechat-login" bindtap="openPhoneAuthSheet">微信手机号授权登录</button>
      <view class="login-tip">体验验证码 / 密码：123456</view>
      <view wx:if="{{authError}}" class="auth-error">{{authError}}</view>
    </view>

    <view wx:if="{{phoneAuthSheetVisible}}" class="auth-mask" catchtouchmove="noop">
      <view class="auth-sheet">
        <view class="auth-head">
          <view>
            <view class="auth-app">班次小助手</view>
            <view class="auth-title">申请获取并验证你的手机号</view>
            <view class="auth-subtitle">用于识别超级管理员、店长或普通员工身份</view>
          </view>
          <button class="auth-info" bindtap="closePhoneAuthSheet">×</button>
        </view>

        <view class="phone-preview">
          <view class="phone-preview-main">微信绑定手机号</view>
          <view class="phone-preview-sub">授权后将自动完成登录</view>
        </view>

        <view class="privacy-row" bindtap="togglePrivacyAccepted">
          <view class="check-dot {{privacyAccepted ? 'checked' : ''}}">✓</view>
          <view>我已阅读并同意服务条款和隐私协议</view>
        </view>

        <button
          class="auth-primary {{privacyAccepted ? '' : 'disabled'}}"
          disabled="{{!privacyAccepted}}"
          open-type="getPhoneNumber"
          bindgetphonenumber="getPhoneNumber"
        >授权手机号并登录</button>
        <button class="auth-cancel" bindtap="closePhoneAuthSheet">取消</button>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="workbench-hero">
      <view class="hero-main">
        <view class="avatar-badge">{{currentStoreInitial || '班'}}</view>
        <view class="hero-title-wrap">
          <view class="workbench-title">工作台</view>
          <view class="workbench-subtitle">{{isAdminSide ? (isSuperAdmin ? '超级管理员' : '店长') : '员工端'}} · {{currentStaffName || '已登录'}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{isAdminSide}}" class="store-strip">
      <view>
        <view class="store-strip-label">当前门店</view>
        <view class="store-strip-name">{{currentStoreName || '选择门店'}}</view>
      </view>
      <picker wx:if="{{isSuperAdmin}}" mode="selector" range="{{stores}}" range-key="name" value="{{currentStoreIndex}}" bindchange="selectStore">
        <view class="store-switch">切换</view>
      </picker>
    </view>

    <view wx:if="{{isAdminSide}}" class="app-group">
      <view class="group-title">门店运营</view>
      <view class="mini-app-grid">
        <navigator class="mini-app" url="/pages/schedule/schedule" open-type="switchTab">
          <view class="mini-icon icon-schedule">
            <view class="icon-calendar-shape"></view>
          </view>
          <view class="mini-title">门店班表</view>
        </navigator>
        <view class="mini-app" bindtap="openStaffOnboard">
          <view class="mini-icon icon-onboard">
            <view class="icon-plus-person">+</view>
          </view>
          <view class="mini-title">员工入职</view>
        </view>
        <view class="mini-app" bindtap="openStaffList">
          <view class="mini-icon icon-staff">
            <view class="icon-person-shape"></view>
          </view>
          <view class="mini-title">员工查询</view>
        </view>
        <navigator class="mini-app" url="/pages/settings/settings">
          <view class="mini-icon icon-store">
            <view class="icon-shop-shape"></view>
          </view>
          <view class="mini-title">门店规则</view>
        </navigator>
        <navigator class="mini-app" url="/pages/settings/settings">
          <view class="mini-icon icon-shift">
            <view class="icon-clock-shape"></view>
          </view>
          <view class="mini-title">班次人数</view>
        </navigator>
      </view>
    </view>

    <view wx:if="{{isAdminSide}}" class="app-group system-group">
      <view class="group-title">系统工具</view>
      <view class="mini-app-grid">
        <navigator class="mini-app" url="/pages/settings/settings">
          <view class="mini-icon icon-settings">
            <view class="icon-settings-shape">
              <view class="icon-settings-dot"></view>
            </view>
          </view>
          <view class="mini-title">设置中心</view>
        </navigator>
        <view class="mini-app" bindtap="clearEmployeeBind">
          <view class="mini-icon icon-test">
            <view class="icon-tool-shape">✓</view>
          </view>
          <view class="mini-title">测试工具</view>
        </view>
      </view>
    </view>

    <view wx:if="{{role === 'employee' && canUseEmployeeFeatures}}" class="app-group">
      <view class="group-title">员工自助</view>
      <view class="mini-app-grid">
        <navigator class="mini-app" url="/pages/schedule/schedule" open-type="switchTab">
          <view class="mini-icon icon-schedule"><view class="icon-calendar-shape"></view></view>
          <view class="mini-title">我的班次</view>
        </navigator>
        <navigator class="mini-app" url="/pages/attendance/attendance">
          <view class="mini-icon icon-attendance"><view class="icon-check-shape">✓</view></view>
          <view class="mini-title">员工打卡</view>
        </navigator>
      </view>
    </view>
  </block>
</view>
