.login-page {
  min-height: 100vh;
  padding: 88rpx 44rpx 48rpx;
  background: #ffffff;
  box-sizing: border-box;
  overflow-x: hidden;
}

.simple-login,
.auto-login {
  width: 100%;
  max-width: 560rpx;
  margin: 0 auto;
  display: grid;
  gap: 24rpx;
  box-sizing: border-box;
}

.auto-login {
  min-height: 70vh;
  align-content: center;
}

.brand {
  color: #646a73;
  font-size: 26rpx;
  font-weight: 700;
}

.login-title,
.auto-title {
  color: #1f2329;
  font-size: 56rpx;
  line-height: 72rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.auto-subtitle,
.login-copy {
  color: #8a8f99;
  font-size: 26rpx;
  line-height: 38rpx;
}

.login-copy {
  margin-top: -12rpx;
}

.auth-error {
  min-height: 40rpx;
  color: #e64340;
  font-size: 24rpx;
  line-height: 36rpx;
}

.login-tabs {
  width: 100%;
  max-width: 100%;
  height: 72rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6rpx;
  padding: 6rpx;
  border: 1rpx solid #e5e6eb;
  border-radius: 10rpx;
  background: #f7f8fa;
  box-sizing: border-box;
}

.tab-btn {
  width: 100%;
  min-width: 0;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background: transparent;
  color: #646a73;
  font-size: 26rpx;
  line-height: 58rpx;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
  overflow: hidden;
  white-space: nowrap;
}

.tab-btn.active {
  background: #ffffff;
  color: #1f2329;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(31, 35, 41, 0.08);
}

.login-primary::after,
.wechat-login::after {
  border: 0;
}

.login-form {
  width: 100%;
  display: grid;
  gap: 16rpx;
  box-sizing: border-box;
}

.login-input {
  width: 100%;
  max-width: 100%;
  min-width: 0;
  height: 96rpx;
  display: block;
  border: 1rpx solid #e5e6eb;
  border-radius: 8rpx;
  padding: 0 24rpx;
  color: #1f2329;
  font-size: 30rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.credential-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 14rpx;
  align-items: center;
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

.credential-row.password-mode {
  grid-template-columns: minmax(0, 1fr);
}

.credential-input {
  min-width: 0;
}

.code-btn {
  width: 100%;
  max-width: 100%;
  min-width: 0;
  height: 86rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background: #f2f3f5;
  color: #1f2329;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 86rpx;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
  overflow: hidden;
  white-space: nowrap;
}

.login-primary,
.wechat-login {
  width: 100%;
  max-width: 360rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 96rpx;
  padding: 0;
  margin-left: auto;
  margin-right: auto;
  box-sizing: border-box;
  overflow: hidden;
  white-space: nowrap;
}

.login-primary {
  margin-top: 10rpx;
  background: #07c160;
  color: #ffffff;
}

.wechat-login {
  margin-top: 8rpx;
  background: #f2f3f5;
  color: #1f2329;
}

.login-tip {
  color: #8a8f99;
  font-size: 24rpx;
  line-height: 34rpx;
}

.auth-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 2000;
  display: flex;
  align-items: flex-end;
  background: rgba(0, 0, 0, 0.55);
}

.auth-sheet {
  width: 100%;
  padding: 34rpx 32rpx calc(42rpx + env(safe-area-inset-bottom));
  border-radius: 24rpx 24rpx 0 0;
  background: #ffffff;
  box-sizing: border-box;
}

.auth-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 34rpx;
}

.auth-head > view {
  min-width: 0;
}

.auth-app {
  color: #8a8f99;
  font-size: 24rpx;
  line-height: 34rpx;
  margin-bottom: 20rpx;
}

.auth-title {
  color: #1f2329;
  font-size: 34rpx;
  line-height: 46rpx;
  font-weight: 800;
}

.auth-subtitle {
  color: #8a8f99;
  font-size: 26rpx;
  line-height: 38rpx;
  margin-top: 6rpx;
}

.auth-info {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  border: 0;
  background: transparent;
  color: #8a8f99;
  font-size: 44rpx;
  line-height: 52rpx;
  padding: 0;
  margin: 0;
  flex-shrink: 0;
  font-weight: 400;
}

.auth-info::after,
.auth-primary::after,
.auth-cancel::after {
  border: 0;
}

.phone-preview {
  min-height: 132rpx;
  display: grid;
  align-content: center;
  justify-items: center;
  border-radius: 10rpx;
  background: #f7f8fa;
  margin-bottom: 28rpx;
}

.phone-preview-main {
  color: #1f2329;
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 700;
}

.phone-preview-sub {
  color: #07c160;
  font-size: 24rpx;
  line-height: 34rpx;
  margin-top: 6rpx;
}

.privacy-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: #646a73;
  font-size: 25rpx;
  line-height: 36rpx;
  margin-bottom: 28rpx;
}

.check-dot {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  border: 2rpx solid #c9cdd4;
  color: transparent;
  text-align: center;
  line-height: 34rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.check-dot.checked {
  background: #07c160;
  border-color: #07c160;
  color: #ffffff;
}

.auth-primary,
.auth-cancel {
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  line-height: 96rpx;
  padding: 0;
  margin: 0;
}

.auth-primary {
  background: #07c160;
  color: #ffffff;
  font-weight: 800;
}

.auth-primary.disabled {
  background: #c9cdd4;
  color: #ffffff;
}

.auth-cancel {
  margin-top: 18rpx;
  background: #ffffff;
  color: #8a8f99;
}

.workbench-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 28rpx;
}

.workbench-title {
  color: #1f2329;
  font-size: 42rpx;
  line-height: 56rpx;
  font-weight: 800;
  margin-top: 8rpx;
}

.workbench-subtitle {
  color: #8a8f99;
  font-size: 26rpx;
  line-height: 38rpx;
  margin-top: 8rpx;
}

.store-panel {
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.field-label {
  color: #1f2329;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.select-box {
  min-height: 82rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid #e5e6eb;
  border-radius: 8rpx;
  padding: 0 24rpx;
  background: #ffffff;
  color: #1f2329;
}

.workbench-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin: 8rpx 0 28rpx;
}

.hero-main {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar-badge {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: linear-gradient(135deg, #dff7ef 0%, #bfe8ff 100%);
  color: #16845c;
  font-size: 32rpx;
  font-weight: 800;
  box-shadow: 0 8rpx 22rpx rgba(7, 193, 96, 0.16);
}

.hero-title-wrap {
  min-width: 0;
}

.workbench-hero .workbench-title {
  margin-top: 0;
  font-size: 50rpx;
  line-height: 62rpx;
}

.workbench-hero .workbench-subtitle {
  margin-top: 2rpx;
  max-width: 420rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.store-strip {
  min-height: 94rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 24rpx;
  margin-bottom: 22rpx;
  border: 1rpx solid #edf0f5;
  border-radius: 18rpx;
  background: #ffffff;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 41, 0.035);
}

.store-strip-label {
  color: #8a8f99;
  font-size: 22rpx;
  line-height: 30rpx;
  margin-bottom: 8rpx;
}

.store-strip-name {
  max-width: 430rpx;
  color: #1f2329;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.store-switch {
  height: 52rpx;
  min-width: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #f2f7ff;
  color: #1677ff;
  font-size: 24rpx;
  font-weight: 700;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.app-group {
  padding: 30rpx 28rpx 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #e8ebf0;
  border-radius: 18rpx;
  background: #ffffff;
  box-sizing: border-box;
  box-shadow: 0 10rpx 26rpx rgba(31, 35, 41, 0.03);
}

.system-group {
  margin-bottom: 28rpx;
}

.group-title {
  color: #1f2329;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 40rpx;
  margin-bottom: 30rpx;
}

.mini-app-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  column-gap: 10rpx;
  row-gap: 34rpx;
}

.mini-app {
  min-width: 0;
  display: grid;
  justify-items: center;
  align-content: start;
  gap: 14rpx;
  padding: 0 2rpx;
  box-sizing: border-box;
}

.mini-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 18rpx rgba(31, 35, 41, 0.07);
  position: relative;
  overflow: hidden;
}

.mini-icon::after {
  content: "";
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  top: 8rpx;
  height: 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
}

.mini-title {
  max-width: 126rpx;
  min-height: 64rpx;
  color: #1f2329;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 34rpx;
  text-align: center;
  word-break: break-all;
}

.icon-schedule {
  background: linear-gradient(135deg, #2cc8ff 0%, #1588ff 100%);
}

.icon-onboard {
  background: linear-gradient(135deg, #22d6a8 0%, #08bf72 100%);
}

.icon-staff {
  background: linear-gradient(135deg, #7d90ff 0%, #4268ff 100%);
}

.icon-store {
  background: linear-gradient(135deg, #19cfbd 0%, #00a889 100%);
}

.icon-shift {
  background: linear-gradient(135deg, #ffc83d 0%, #ffad18 100%);
}

.icon-test {
  background: linear-gradient(135deg, #ff7777 0%, #f05252 100%);
}

.icon-settings {
  background: linear-gradient(135deg, #9a7cff 0%, #6f55f5 100%);
}

.icon-attendance {
  background: linear-gradient(135deg, #44dab2 0%, #09bf78 100%);
}

.icon-calendar-shape,
.icon-person-shape,
.icon-shop-shape,
.icon-clock-shape,
.icon-settings-shape {
  width: 40rpx;
  height: 40rpx;
  border: 6rpx solid #ffffff;
  border-radius: 10rpx;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

.icon-calendar-shape::before {
  content: "";
  position: absolute;
  left: -6rpx;
  right: -6rpx;
  top: 10rpx;
  height: 6rpx;
  background: #ffffff;
}

.icon-calendar-shape::after {
  content: "";
  position: absolute;
  left: 8rpx;
  top: 24rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 16rpx 0 0 #ffffff;
}

.icon-plus-person,
.icon-check-shape,
.icon-tool-shape {
  color: #ffffff;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1;
  position: relative;
  z-index: 1;
}

.icon-person-shape {
  border-radius: 50% 50% 16rpx 16rpx;
}

.icon-person-shape::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: -22rpx;
  width: 54rpx;
  height: 34rpx;
  border-radius: 50%;
  border: 6rpx solid #ffffff;
  transform: translateX(-50%);
}

.icon-shop-shape::before {
  content: "";
  position: absolute;
  left: -8rpx;
  right: -8rpx;
  top: -16rpx;
  height: 20rpx;
  border-radius: 8rpx 8rpx 2rpx 2rpx;
  background: #ffffff;
}

.icon-clock-shape {
  border-radius: 50%;
}

.icon-clock-shape::before,
.icon-clock-shape::after {
  content: "";
  position: absolute;
  left: 18rpx;
  top: 8rpx;
  width: 6rpx;
  height: 18rpx;
  border-radius: 4rpx;
  background: #ffffff;
}

.icon-clock-shape::after {
  top: 20rpx;
  width: 18rpx;
  height: 6rpx;
}

.icon-settings-shape {
  border-radius: 50%;
}

.icon-settings-shape::before,
.icon-settings-shape::after {
  content: "";
  position: absolute;
  left: 50%;
  top: -12rpx;
  width: 6rpx;
  height: 52rpx;
  border-radius: 999rpx;
  background: #ffffff;
  transform: translateX(-50%);
}

.icon-settings-shape::after {
  transform: translateX(-50%) rotate(90deg);
}

.icon-settings-dot {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ffffff;
  transform: translate(-50%, -50%);
  z-index: 2;
}
