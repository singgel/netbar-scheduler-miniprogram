.login-page {
  min-height: 100vh;
  padding: 88rpx 44rpx 48rpx;
  background: #ffffff;
  box-sizing: border-box;
  overflow-x: hidden;
}

.simple-login,
.auto-login {
  width: 100%;
  max-width: 560rpx;
  margin: 0 auto;
  display: grid;
  gap: 24rpx;
  box-sizing: border-box;
}

.auto-login {
  min-height: 70vh;
  align-content: center;
}

.brand {
  color: #646a73;
  font-size: 26rpx;
  font-weight: 700;
}

.login-title,
.auto-title {
  color: #1f2329;
  font-size: 56rpx;
  line-height: 72rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.auto-subtitle,
.login-copy {
  color: #8a8f99;
  font-size: 26rpx;
  line-height: 38rpx;
}

.login-copy {
  margin-top: -12rpx;
}

.auth-error {
  min-height: 40rpx;
  color: #e64340;
  font-size: 24rpx;
  line-height: 36rpx;
}

.login-tabs {
  width: 100%;
  max-width: 100%;
  height: 72rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6rpx;
  padding: 6rpx;
  border: 1rpx solid #e5e6eb;
  border-radius: 10rpx;
  background: #f7f8fa;
  box-sizing: border-box;
}

.tab-btn {
  width: 100%;
  min-width: 0;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background: transparent;
  color: #646a73;
  font-size: 26rpx;
  line-height: 58rpx;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
  overflow: hidden;
  white-space: nowrap;
}

.tab-btn.active {
  background: #ffffff;
  color: #1f2329;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(31, 35, 41, 0.08);
}

.login-primary::after,
.wechat-login::after,
.logout-btn::after {
  border: 0;
}

.login-form {
  width: 100%;
  display: grid;
  gap: 16rpx;
  box-sizing: border-box;
}

.login-input {
  width: 100%;
  max-width: 100%;
  min-width: 0;
  height: 96rpx;
  display: block;
  border: 1rpx solid #e5e6eb;
  border-radius: 8rpx;
  padding: 0 24rpx;
  color: #1f2329;
  font-size: 30rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.credential-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 14rpx;
  align-items: center;
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

.credential-row.password-mode {
  grid-template-columns: minmax(0, 1fr);
}

.credential-input {
  min-width: 0;
}

.code-btn {
  width: 100%;
  max-width: 100%;
  min-width: 0;
  height: 86rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background: #f2f3f5;
  color: #1f2329;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 86rpx;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
  overflow: hidden;
  white-space: nowrap;
}

.login-primary,
.wechat-login {
  width: 100%;
  max-width: 360rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 96rpx;
  padding: 0;
  margin-left: auto;
  margin-right: auto;
  box-sizing: border-box;
  overflow: hidden;
  white-space: nowrap;
}

.login-primary {
  margin-top: 10rpx;
  background: #07c160;
  color: #ffffff;
}

.wechat-login {
  margin-top: 8rpx;
  background: #f2f3f5;
  color: #1f2329;
}

.login-tip {
  color: #8a8f99;
  font-size: 24rpx;
  line-height: 34rpx;
}

.auth-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 2000;
  display: flex;
  align-items: flex-end;
  background: rgba(0, 0, 0, 0.55);
}

.auth-sheet {
  width: 100%;
  padding: 34rpx 32rpx calc(42rpx + env(safe-area-inset-bottom));
  border-radius: 24rpx 24rpx 0 0;
  background: #ffffff;
  box-sizing: border-box;
}

.auth-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 34rpx;
}

.auth-head > view {
  min-width: 0;
}

.auth-app {
  color: #8a8f99;
  font-size: 24rpx;
  line-height: 34rpx;
  margin-bottom: 20rpx;
}

.auth-title {
  color: #1f2329;
  font-size: 34rpx;
  line-height: 46rpx;
  font-weight: 800;
}

.auth-subtitle {
  color: #8a8f99;
  font-size: 26rpx;
  line-height: 38rpx;
  margin-top: 6rpx;
}

.auth-info {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  border: 0;
  background: transparent;
  color: #8a8f99;
  font-size: 44rpx;
  line-height: 52rpx;
  padding: 0;
  margin: 0;
  flex-shrink: 0;
  font-weight: 400;
}

.auth-info::after,
.auth-primary::after,
.auth-cancel::after {
  border: 0;
}

.phone-preview {
  min-height: 132rpx;
  display: grid;
  align-content: center;
  justify-items: center;
  border-radius: 10rpx;
  background: #f7f8fa;
  margin-bottom: 28rpx;
}

.phone-preview-main {
  color: #1f2329;
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 700;
}

.phone-preview-sub {
  color: #07c160;
  font-size: 24rpx;
  line-height: 34rpx;
  margin-top: 6rpx;
}

.privacy-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: #646a73;
  font-size: 25rpx;
  line-height: 36rpx;
  margin-bottom: 28rpx;
}

.check-dot {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  border: 2rpx solid #c9cdd4;
  color: transparent;
  text-align: center;
  line-height: 34rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.check-dot.checked {
  background: #07c160;
  border-color: #07c160;
  color: #ffffff;
}

.auth-primary,
.auth-cancel {
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  line-height: 96rpx;
  padding: 0;
  margin: 0;
}

.auth-primary {
  background: #07c160;
  color: #ffffff;
  font-weight: 800;
}

.auth-primary.disabled {
  background: #c9cdd4;
  color: #ffffff;
}

.auth-cancel {
  margin-top: 18rpx;
  background: #ffffff;
  color: #8a8f99;
}

.workbench-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 28rpx;
}

.workbench-title {
  color: #1f2329;
  font-size: 42rpx;
  line-height: 56rpx;
  font-weight: 800;
  margin-top: 8rpx;
}

.workbench-subtitle {
  color: #8a8f99;
  font-size: 26rpx;
  line-height: 38rpx;
  margin-top: 8rpx;
}

.logout-btn {
  min-width: 104rpx;
  height: 56rpx;
  border-radius: 8rpx;
  background: #f2f3f5;
  color: #646a73;
  font-size: 24rpx;
  line-height: 56rpx;
  padding: 0 18rpx;
  margin: 0;
}

.store-panel {
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.field-label {
  color: #1f2329;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.select-box {
  min-height: 82rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid #e5e6eb;
  border-radius: 8rpx;
  padding: 0 24rpx;
  background: #ffffff;
  color: #1f2329;
}

.quick-grid {
  display: grid;
  gap: 0;
  margin-top: 0;
}

.quick-card {
  background: transparent;
  border: 0;
  border-bottom: 1rpx solid #edf0f5;
  border-radius: 0;
  padding: 28rpx 26rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.quick-card:last-child {
  border-bottom: 0;
}

.quick-main {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-width: 0;
}

.quick-title {
  color: #1f2329;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.chevron {
  color: #c9cdd4;
  font-size: 42rpx;
  line-height: 48rpx;
  flex-shrink: 0;
}
