.hero {
  min-height: 220rpx;
  background: linear-gradient(135deg, #07c160 0%, #10b981 100%);
  border-radius: 18rpx;
  padding: 32rpx;
  box-sizing: border-box;
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  color: #ffffff;
  margin-bottom: 22rpx;
  box-shadow: 0 12rpx 32rpx rgba(7, 193, 96, 0.18);
}

.grouped-panel {
  padding: 26rpx;
}

.eyebrow {
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 58rpx;
}

.hero-subtitle {
  color: rgba(255, 255, 255, 0.86);
  margin-top: 12rpx;
  line-height: 38rpx;
}

.role-pill {
  height: 56rpx;
  min-width: 116rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.36);
  border-radius: 28rpx;
  text-align: center;
  line-height: 56rpx;
  font-size: 24rpx;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.14);
}

.role-grid,
.quick-grid {
  display: grid;
  gap: 0;
}

.debug-switch {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 20rpx;
  padding: 8rpx;
  border-radius: 12rpx;
  background: #f2f3f5;
}

.mini-switch {
  height: 66rpx;
  border-radius: 8rpx;
  background: transparent;
  color: #646a73;
  font-size: 26rpx;
  line-height: 66rpx;
  padding: 0;
}

.mini-switch.active {
  background: #ffffff;
  color: #07c160;
  box-shadow: 0 4rpx 12rpx rgba(31, 35, 41, 0.06);
}

.mini-switch::after,
.avatar-btn::after,
.phone-btn::after {
  border: 0;
}

.role-grid {
  grid-template-columns: 1fr;
  margin-top: 22rpx;
  border-radius: 14rpx;
  overflow: hidden;
  border: 1rpx solid #edf0f5;
}

.role-card {
  background: #ffffff;
  border: 0;
  border-bottom: 1rpx solid #edf0f5;
  border-radius: 0;
  padding: 26rpx 24rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.role-card:last-child {
  border-bottom: 0;
}

.role-card.active {
  background: #ffffff;
  box-shadow: none;
}

.role-main,
.quick-main {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-width: 0;
}

.role-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  border: 3rpx solid #c9cdd4;
  flex-shrink: 0;
}

.role-card.active .role-dot {
  background: #07c160;
  border-color: #07c160;
}

.role-name,
.quick-title {
  color: #1f2329;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.store-picker,
.employee-login {
  margin-top: 28rpx;
}

.employee-login {
  display: grid;
  gap: 18rpx;
}

.login-head,
.login-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 12rpx;
  background: #edf0f5;
  flex-shrink: 0;
}

.avatar-btn,
.phone-btn {
  height: 78rpx;
  border-radius: 10rpx;
  background: #f2f3f5;
  color: #1f2329;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 78rpx;
  margin: 0;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-shadow: none;
}

.phone-btn {
  background: #07c160;
  color: #ffffff;
  box-shadow: none;
}

.status {
  min-width: 120rpx;
  height: 58rpx;
  border-radius: 8rpx;
  background: #f2f3f5;
  color: #8a8f99;
  font-size: 24rpx;
  text-align: center;
  line-height: 58rpx;
  flex-shrink: 0;
}

.status.done {
  background: #e8f8ef;
  color: #07c160;
}

.nickname-input {
  width: 100%;
}

.staff-picker {
  margin-top: 4rpx;
}

.field-label {
  color: #1f2329;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.select-box {
  min-height: 82rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid #e5e6eb;
  border-radius: 10rpx;
  padding: 0 24rpx;
  background: #ffffff;
  color: #1f2329;
}

.bind-tip {
  margin-top: 8rpx;
  font-size: 24rpx;
}

.invite-status {
  min-height: 48rpx;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  border-radius: 8rpx;
  margin-top: 10rpx;
  background: #f2f3f5;
  color: #8a8f99;
  font-size: 24rpx;
}

.invite-status.matched {
  background: #e8f8ef;
  color: #07c160;
}

.quick-grid {
  margin-top: 0;
}

.quick-card {
  background: transparent;
  border: 0;
  border-bottom: 1rpx solid #edf0f5;
  border-radius: 0;
  padding: 28rpx 26rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.quick-card:last-child {
  border-bottom: 0;
}

.chevron {
  color: #c9cdd4;
  font-size: 42rpx;
  line-height: 48rpx;
  flex-shrink: 0;
}
