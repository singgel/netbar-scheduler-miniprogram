.hero {
  min-height: 248rpx;
  background: #111111;
  border-radius: 28rpx;
  padding: 34rpx;
  box-sizing: border-box;
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  color: #ffffff;
  margin-bottom: 28rpx;
  box-shadow: 0 28rpx 70rpx rgba(0, 0, 0, 0.18);
}

.grouped-panel {
  padding: 24rpx;
}

.eyebrow {
  color: #a1a1a6;
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.hero-title {
  font-size: 50rpx;
  font-weight: 800;
  line-height: 62rpx;
}

.hero-subtitle {
  color: #d2d2d7;
  margin-top: 12rpx;
  line-height: 38rpx;
}

.role-pill {
  height: 56rpx;
  min-width: 116rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  border-radius: 999rpx;
  text-align: center;
  line-height: 56rpx;
  font-size: 24rpx;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.08);
}

.role-grid,
.quick-grid {
  display: grid;
  gap: 0;
}

.debug-switch {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 20rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: #f5f5f7;
}

.mini-switch {
  height: 66rpx;
  border-radius: 999rpx;
  background: transparent;
  color: #6e6e73;
  font-size: 26rpx;
  line-height: 66rpx;
  padding: 0;
}

.mini-switch.active {
  background: #ffffff;
  color: #111111;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.mini-switch::after,
.avatar-btn::after,
.phone-btn::after {
  border: 0;
}

.role-grid {
  grid-template-columns: 1fr;
  margin-top: 22rpx;
  border-radius: 22rpx;
  overflow: hidden;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
}

.role-card {
  background: #fbfbfd;
  border: 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
  border-radius: 0;
  padding: 26rpx 24rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.role-card:last-child {
  border-bottom: 0;
}

.role-card.active {
  background: #ffffff;
  box-shadow: none;
}

.role-main,
.quick-main {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-width: 0;
}

.role-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  border: 3rpx solid #d2d2d7;
  flex-shrink: 0;
}

.role-card.active .role-dot {
  background: #111111;
  border-color: #111111;
}

.role-name,
.quick-title {
  color: #1d1d1f;
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 10rpx;
}

.store-picker,
.employee-login {
  margin-top: 28rpx;
}

.employee-login {
  display: grid;
  gap: 18rpx;
}

.login-head,
.login-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: #e8e8ed;
  flex-shrink: 0;
}

.avatar-btn,
.phone-btn {
  height: 78rpx;
  border-radius: 999rpx;
  background: #f5f5f7;
  color: #111111;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 78rpx;
  margin: 0;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-shadow: inset 0 0 0 1rpx rgba(0, 0, 0, 0.06);
}

.phone-btn {
  background: #111111;
  color: #ffffff;
  box-shadow: 0 14rpx 30rpx rgba(0, 0, 0, 0.16);
}

.status {
  min-width: 120rpx;
  height: 58rpx;
  border-radius: 999rpx;
  background: #f5f5f7;
  color: #86868b;
  font-size: 24rpx;
  text-align: center;
  line-height: 58rpx;
  flex-shrink: 0;
}

.status.done {
  background: #e8f8f2;
  color: #047857;
}

.nickname-input {
  width: 100%;
}

.staff-picker {
  margin-top: 4rpx;
}

.field-label {
  color: #1d1d1f;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.select-box {
  min-height: 82rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  border-radius: 18rpx;
  padding: 0 24rpx;
  background: #f5f5f7;
  color: #1d1d1f;
}

.bind-tip {
  margin-top: 8rpx;
  font-size: 24rpx;
}

.invite-status {
  min-height: 48rpx;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  border-radius: 999rpx;
  margin-top: 10rpx;
  background: #f5f5f7;
  color: #86868b;
  font-size: 24rpx;
}

.invite-status.matched {
  background: #e8f8f2;
  color: #047857;
}

.quick-grid {
  margin-top: 0;
}

.quick-card {
  background: transparent;
  border: 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
  border-radius: 0;
  padding: 28rpx 26rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.quick-card:last-child {
  border-bottom: 0;
}

.chevron {
  color: #c7c7cc;
  font-size: 48rpx;
  line-height: 48rpx;
  flex-shrink: 0;
}
