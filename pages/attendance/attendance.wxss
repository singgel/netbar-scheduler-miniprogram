.today {
  margin: 8rpx 0 18rpx;
}

.select-box {
  min-height: 82rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid #e5e6eb;
  border-radius: 10rpx;
  padding: 0 24rpx;
  margin-top: 14rpx;
  background: #ffffff;
  color: #1f2329;
}

.identity-card {
  min-height: 96rpx;
  background: #f7f8fa;
  border: 1rpx solid #edf0f5;
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
  box-sizing: border-box;
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.identity-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 10rpx;
  background: #edf0f5;
  flex-shrink: 0;
}

.identity-name {
  color: #1f2329;
  font-size: 32rpx;
  font-weight: 800;
  margin-top: 4rpx;
}

.guard-panel {
  display: grid;
  gap: 16rpx;
}

.guard-btn {
  margin-top: 8rpx;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 20rpx;
}

.record-list {
  margin-top: 24rpx;
}

.location-tip {
  margin-top: 14rpx;
  font-size: 24rpx;
}

.list-title {
  margin-bottom: 14rpx;
}

.empty-card,
.record-card {
  background: #ffffff;
  border: 1rpx solid #edf0f5;
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 41, 0.04);
}

.empty-card {
  color: #8a8f99;
}

.record-card {
  min-height: 112rpx;
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 14rpx;
}

.record-main {
  color: #1f2329;
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 6rpx;
}

.record-time {
  color: #646a73;
  font-size: 24rpx;
  line-height: 36rpx;
  text-align: right;
  flex-shrink: 0;
}
