<view wx:if="{{!hidden}}" class="custom-tab-bar">
  <view
    wx:for="{{items}}"
    wx:key="pagePath"
    class="tab-item {{selected === item.pagePath ? 'active' : ''}}"
    data-path="{{item.pagePath}}"
    bindtap="switchTab"
  >
    <view class="tab-icon">{{item.icon}}</view>
    <view class="tab-text">{{item.text}}</view>
  </view>
</view>
