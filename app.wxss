page {
  background: #f7f8fa;
  color: #1f2329;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: calc(148rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #edf0f5;
  border-radius: 16rpx;
  padding: 28rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 41, 0.04);
}

.section-title {
  color: #1f2329;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.section-label {
  color: #646a73;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0;
  margin: 22rpx 6rpx 12rpx;
}

.list-panel {
  background: #ffffff;
  border: 1rpx solid #edf0f5;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 41, 0.04);
  overflow: hidden;
}

.muted {
  color: #8a8f99;
}

.btn {
  height: 82rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 82rpx;
  border: 0;
  box-shadow: none;
  transition: opacity 0.18s ease;
}

.btn::after {
  border: 0;
}

.btn-primary {
  background: #07c160;
  color: #ffffff;
}

.btn-ghost {
  background: #f2f3f5;
  color: #1f2329;
}

.btn-danger {
  background: #fff2f0;
  color: #e64340;
}

.btn-icon {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 34rpx;
  flex-shrink: 0;
}

.btn-primary .btn-icon {
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
}

.btn-ghost .btn-icon {
  background: #ffffff;
  color: #1f2329;
}

.btn-danger .btn-icon,
.danger-btn .btn-icon {
  background: rgba(230, 67, 64, 0.1);
  color: #e64340;
}

.icon-tile {
  width: 58rpx;
  height: 58rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f2f3f5;
  color: #1f2329;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 58rpx;
  flex-shrink: 0;
}

.icon-tile.dark {
  background: #07c160;
  color: #ffffff;
}

.icon-tile.blue {
  background: #e8f7ff;
  color: #1485ee;
}

.icon-tile.green {
  background: #e8f8ef;
  color: #07c160;
}

.icon-tile.red {
  background: #fff2f0;
  color: #e64340;
}

.input {
  min-height: 82rpx;
  border: 1rpx solid #e5e6eb;
  border-radius: 10rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  background: #ffffff;
  color: #1f2329;
}
