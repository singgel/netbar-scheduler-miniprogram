page {
  background: #f5f5f7;
  color: #1d1d1f;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.panel {
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  border-radius: 24rpx;
  padding: 30rpx;
  box-sizing: border-box;
  box-shadow: 0 18rpx 48rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  color: #1d1d1f;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 46rpx;
}

.section-label {
  color: #86868b;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0;
  margin: 10rpx 10rpx 12rpx;
}

.list-panel {
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  border-radius: 24rpx;
  box-shadow: 0 18rpx 48rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.muted {
  color: #86868b;
}

.btn {
  height: 80rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 80rpx;
  border: 0;
  box-shadow: inset 0 0 0 1rpx rgba(0, 0, 0, 0.06);
  transition: opacity 0.18s ease;
}

.btn::after {
  border: 0;
}

.btn-primary {
  background: #111111;
  color: #ffffff;
  box-shadow: 0 16rpx 34rpx rgba(0, 0, 0, 0.18);
}

.btn-ghost {
  background: rgba(255, 255, 255, 0.92);
  color: #111111;
}

.btn-danger {
  background: #fff1f2;
  color: #be123c;
}

.btn-icon {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 34rpx;
  flex-shrink: 0;
}

.btn-primary .btn-icon {
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
}

.btn-ghost .btn-icon {
  background: #f5f5f7;
  color: #111111;
}

.btn-danger .btn-icon,
.danger-btn .btn-icon {
  background: rgba(190, 18, 60, 0.1);
  color: #be123c;
}

.icon-tile {
  width: 54rpx;
  height: 54rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f7;
  color: #1d1d1f;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 54rpx;
  flex-shrink: 0;
}

.icon-tile.dark {
  background: #111111;
  color: #ffffff;
}

.icon-tile.blue {
  background: #e8f0ff;
  color: #2563eb;
}

.icon-tile.green {
  background: #e8f8f2;
  color: #047857;
}

.icon-tile.red {
  background: #fff1f2;
  color: #be123c;
}

.input {
  min-height: 82rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  border-radius: 18rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  background: #f5f5f7;
  color: #1d1d1f;
}
